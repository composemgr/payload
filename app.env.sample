# Payload CMS environment configuration
# Copy to app.env and adjust values as needed

# Timezone
TZ=America/New_York

# Application secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database (MongoDB)
DB_CREATE_DATABASE_NAME=payload
DB_ADMIN_USER=root
DB_ADMIN_PASS=changeme_admin_password
